{
  "name": "moondark",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "ready": "vp fmt && vp lint && vp run -r test && vp run -r build",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:dashboard": "bun run --cwd apps/dashboard dev",
    "dev:signaling": "go run ./packages/signaling/main.go",
    "dev": "bun run dev:api & bun run dev:dashboard",
    "build": "bun run build:api && bun run build:dashboard",
    "build:api": "bun run --cwd apps/api build",
    "build:dashboard": "bun run --cwd apps/dashboard build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "overrides": {
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.11",
  "catalog": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vite-plus": "latest"
  }
}
